m1,m2,m3,m4=map(int,input("").split())
total=m1+m2+m3+m4
print(total)
avg=total/4
print(f"{avg:.2f}")
if avg>75:
	print("Distinction")
elif avg>=60 and avg<75:
	print("First Division")
elif avg>=50 and avg<60:
	print("Second Division")
elif avg>=40 and avg<50:
	print("Third Division")
else:
	print("Fail")
