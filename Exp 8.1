a=int(input("dimension: "))
m1=[]
m2=[]
print("first matrix:")
for i in range(a):
	row=list(map(int,input().split()))
	m1.append(row)
print("second matrix:")
for i in range(a):
	r2=list(map(int,input().split()))
	m2.append(r2)
res=[]
for i in range(a):
	row=[]
	for j in range(a):
		row.append(0)
	res.append(row)
for i in range(a):
	for j in range(a):
		for k in range(a):
			res[i][j]+=m1[i][k]*m2[k][j]
print("Resultant Matrix:")
for i in range(a):
	print(" ".join(map(str,res[i])))
